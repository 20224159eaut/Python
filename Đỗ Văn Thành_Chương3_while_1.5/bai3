n = int(input("Nhap n: "))

if n < 2:
    print("Khong phai so nguyen to")
else:
    i = 2
    la_so_nguyen_to = True

    while i <= n // 2:
        if n % i == 0:
            la_so_nguyen_to = False
            break
        i += 1

    if la_so_nguyen_to:
        print("Day la so nguyen to")
    else:
        print("Khong phai so nguyen to")
        